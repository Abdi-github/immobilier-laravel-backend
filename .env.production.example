APP_NAME=Immobilier
APP_ENV=production
APP_KEY=base64:YOUR_LARAVEL_APP_KEY_HERE
APP_DEBUG=false
APP_TIMEZONE=Europe/Zurich
APP_URL=https://immobilier.swiftapp.ch
FRONTEND_URL=https://immobilier-react.swiftapp.ch
ADMIN_URL=https://immobilier-admin.swiftapp.ch
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=immobilier_prod
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password_here

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@immobilier.swiftapp.ch
MAIL_FROM_NAME="Immobilier"

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=your_meilisearch_key

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=immobilier_node

DEEPL_API_KEY=
LIBRETRANSLATE_URL=http://libretranslate:5000
LIBRETRANSLATE_API_KEY=

SANCTUM_STATEFUL_DOMAINS=immobilier-react.swiftapp.ch,immobilier-admin.swiftapp.ch
SESSION_DOMAIN=.swiftapp.ch

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

HORIZON_PREFIX=immobilier_horizon:
VITE_APP_NAME="${APP_NAME}"
