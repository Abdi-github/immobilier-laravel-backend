APP_NAME=Immobilier
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Zurich
APP_URL=http://localhost:4003
FRONTEND_URL=http://localhost:5174
ADMIN_URL=http://localhost:5175

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ── Database (PostgreSQL) ──
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=immobilier
DB_USERNAME=immobilier
DB_PASSWORD=immobilier_secret

# ── Cache ──
CACHE_STORE=redis

# ── Session ──
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Queue ──
QUEUE_CONNECTION=redis

# ── Redis ──
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (Mailpit) ──
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@immobilier.ch
MAIL_FROM_NAME="Immobilier.ch"

# ── Search (Meilisearch) ──
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey

# ── Cloudinary ──
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Translation Providers ──
DEEPL_API_KEY=
LIBRETRANSLATE_URL=http://libretranslate:5000
LIBRETRANSLATE_API_KEY=

# ── Sanctum ──
SANCTUM_STATEFUL_DOMAINS=localhost:4003

# ── Logging ──
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Horizon ──
HORIZON_PREFIX=immobilier_horizon:

# ── Vite (disabled for API-only) ──
VITE_APP_NAME="${APP_NAME}"
